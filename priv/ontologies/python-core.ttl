# covers: python_ontology.ontology_turtle_files.files_present python_ontology.ontology_turtle_files.layered_files python_ontology.ontology_turtle_files.namespace_stability python_ontology.ontology_turtle_files.python_native_boundaries python_ontology.ontology_turtle_files.dynamic_fact_boundary python_ontology.ontology_turtle_files.bootstrap_validity python_ontology.fact_confidence_model.categories python_ontology.fact_confidence_model.unresolved_queryable python_ontology.fact_confidence_model.runtime_dependent_boundary python_ontology.fact_confidence_model.builder_propagation python_ontology.fact_confidence_model.queryable_confidence python_ontology.validation_strategy.turtle_parse_gate python_ontology.validation_strategy.owl_open_world python_ontology.validation_strategy.no_validation_by_execution python_ontology.initial_analysis_slice.imports_aliases python_ontology.initial_analysis_slice.calls_attributes python_ontology.initial_analysis_slice.out_of_scope_runtime
@prefix : <https://w3id.org/python-code/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

<https://w3id.org/python-code/core> a owl:Ontology ;
    dc:title "Python Code Core Ontology"@en ;
    rdfs:comment "Foundational ontology for Python source files, locations, AST nodes, expressions, statements, scopes, bindings, and fact confidence boundaries."@en .

:PythonCodeElement a owl:Class ;
    rdfs:label "Python Code Element"@en .

:SourceFile a owl:Class ;
    rdfs:subClassOf :PythonCodeElement ;
    rdfs:label "Source File"@en .

:SourceLocation a owl:Class ;
    rdfs:label "Source Location"@en .

:ASTNode a owl:Class ;
    rdfs:subClassOf :PythonCodeElement ;
    rdfs:label "AST Node"@en .

:Statement a owl:Class ;
    rdfs:subClassOf :ASTNode ;
    rdfs:label "Statement"@en .

:Expression a owl:Class ;
    rdfs:subClassOf :ASTNode ;
    rdfs:label "Expression"@en .

:Literal a owl:Class ;
    rdfs:subClassOf :Expression ;
    rdfs:label "Literal"@en .

:ImportStatement a owl:Class ;
    rdfs:subClassOf :Statement ;
    rdfs:label "Import Statement"@en .

:ImportAlias a owl:Class ;
    rdfs:subClassOf :Binding ;
    rdfs:label "Import Alias"@en .

:Assignment a owl:Class ;
    rdfs:subClassOf :Statement ;
    rdfs:label "Assignment"@en .

:CallExpression a owl:Class ;
    rdfs:subClassOf :Expression ;
    rdfs:label "Call Expression"@en .

:AttributeExpression a owl:Class ;
    rdfs:subClassOf :Expression ;
    rdfs:label "Attribute Expression"@en .

:SubscriptExpression a owl:Class ;
    rdfs:subClassOf :Expression ;
    rdfs:label "Subscript Expression"@en .

:Comprehension a owl:Class ;
    rdfs:subClassOf :Expression ;
    rdfs:label "Comprehension"@en .

:ControlFlowStatement a owl:Class ;
    rdfs:subClassOf :Statement ;
    rdfs:label "Control Flow Statement"@en .

:Scope a owl:Class ;
    rdfs:label "Scope"@en .

:Binding a owl:Class ;
    rdfs:label "Binding"@en .

:FactAssertion a owl:Class ;
    rdfs:comment "A generated assertion about Python source, annotated with confidence and evidence so consumers can query certainty explicitly."@en ;
    rdfs:label "Fact Assertion"@en .

:SourceDeclaredFact a owl:Class ;
    rdfs:subClassOf :FactAssertion ;
    rdfs:comment "A fact directly present in parsed source syntax."@en ;
    rdfs:label "Source Declared Fact"@en .

:StaticallyInferredFact a owl:Class ;
    rdfs:subClassOf :FactAssertion ;
    rdfs:comment "A fact derived by deterministic static analysis from source-declared evidence."@en ;
    rdfs:label "Statically Inferred Fact"@en .

:UnresolvedFact a owl:Class ;
    rdfs:subClassOf :FactAssertion ;
    rdfs:comment "A relevant fact that was recognized but could not be resolved statically."@en ;
    rdfs:label "Unresolved Fact"@en .

:RuntimeDependentFact a owl:Class ;
    rdfs:subClassOf :FactAssertion ;
    rdfs:comment "A fact whose truth depends on executing Python code or observing runtime state."@en ;
    rdfs:label "Runtime Dependent Fact"@en .

:Evidence a owl:Class ;
    rdfs:label "Evidence"@en .

:SourceEvidence a owl:Class ;
    rdfs:subClassOf :Evidence ;
    rdfs:label "Source Evidence"@en .

:InferenceEvidence a owl:Class ;
    rdfs:subClassOf :Evidence ;
    rdfs:label "Inference Evidence"@en .

:UnresolvedEvidence a owl:Class ;
    rdfs:subClassOf :Evidence ;
    rdfs:label "Unresolved Evidence"@en .

:RuntimeEvidence a owl:Class ;
    rdfs:subClassOf :Evidence ;
    rdfs:label "Runtime Evidence"@en .

:hasLocation a owl:ObjectProperty ;
    rdfs:domain :PythonCodeElement ;
    rdfs:range :SourceLocation ;
    rdfs:label "has location"@en .

:line a owl:DatatypeProperty ;
    rdfs:domain :SourceLocation ;
    rdfs:range xsd:integer ;
    rdfs:label "line"@en .

:column a owl:DatatypeProperty ;
    rdfs:domain :SourceLocation ;
    rdfs:range xsd:integer ;
    rdfs:label "column"@en .

:hasScope a owl:ObjectProperty ;
    rdfs:domain :PythonCodeElement ;
    rdfs:range :Scope ;
    rdfs:label "has scope"@en .

:bindsName a owl:DatatypeProperty ;
    rdfs:domain :Binding ;
    rdfs:range xsd:string ;
    rdfs:label "binds name"@en .

:hasImportAlias a owl:ObjectProperty ;
    rdfs:domain :ImportStatement ;
    rdfs:range :ImportAlias ;
    rdfs:label "has import alias"@en .

:importName a owl:DatatypeProperty ;
    rdfs:domain :ImportAlias ;
    rdfs:range xsd:string ;
    rdfs:label "import name"@en .

:aliasName a owl:DatatypeProperty ;
    rdfs:domain :ImportAlias ;
    rdfs:range xsd:string ;
    rdfs:label "alias name"@en .

:confidenceCategory a owl:DatatypeProperty ;
    rdfs:domain :FactAssertion ;
    rdfs:range xsd:string ;
    rdfs:comment "Machine-readable confidence category such as source_declared, statically_inferred, unresolved, or runtime_dependent."@en ;
    rdfs:label "confidence category"@en .

:hasEvidence a owl:ObjectProperty ;
    rdfs:domain :FactAssertion ;
    rdfs:range :Evidence ;
    rdfs:label "has evidence"@en .

:evidenceKind a owl:DatatypeProperty ;
    rdfs:domain :Evidence ;
    rdfs:range xsd:string ;
    rdfs:label "evidence kind"@en .

:evidenceReason a owl:DatatypeProperty ;
    rdfs:domain :Evidence ;
    rdfs:range xsd:string ;
    rdfs:label "evidence reason"@en .

:evidenceSource a owl:ObjectProperty ;
    rdfs:domain :Evidence ;
    rdfs:label "evidence source"@en .
